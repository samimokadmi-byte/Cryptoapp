{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "frontend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "frontend/api/app/**"
      }
    }
  ],
  "routes": [
    { "src": "/health",     "dest": "/frontend/api/index.py" },
    { "src": "/api/(.*)",   "dest": "/frontend/api/index.py" }
  ]
}
